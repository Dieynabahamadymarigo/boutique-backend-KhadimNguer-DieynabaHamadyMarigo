                                    "description": {
                                        "type": "string"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Catégorie mise à jour"
                    },
                    "422": {
                        "description": "Erreurs de validation"
                    }
                }
            },
            "delete": {
                "tags": [
                    "Categories"
                ],
                "summary": "Supprimer une catégorie",
                "description": "Remove the specified resource from storage.",
                "operationId": "21fd49657c7df227ca3dd53c5371f438",
                "parameters": [
                    {
                        "name": "categorie",
                        "in": "path",
                        "required": true,
                        "schema": {
