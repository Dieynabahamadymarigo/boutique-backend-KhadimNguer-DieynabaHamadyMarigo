                "responses": {
                    "200": {
                        "description": "Liste des catégories"
                    }
                }
            },
            "post": {
                "tags": [
                    "Categories"
                ],
                "summary": "Créer une catégorie",
                "description": "Store a newly created resource in storage.",
                "operationId": "1d6b893ef899e2aecece0a5e18049d8a",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "nom"
                                ],
                                "properties": {
                                    "nom": {
                                        "type": "string",
                                        "example": "Café"
                                    },
                                    "description": {
                                        "type": "string",
                                        "example": "Une catégorie pour les produits de café"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Catégorie créée"
                    },
                    "422": {
                        "description": "Erreurs de validation"
                    }
                }
            }
        },
        "/api/categories/{categorie}": {
            "get": {
                "tags": [
                    "Categories"
                ],
                "summary": "Détails d'une catégorie avec ses produits",
                "description": "Display the specified resource.",
                "operationId": "204f07a46403659f3e16a6e06e95dcf1",
                "parameters": [
                    {
                        "name": "categorie",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Catégorie trouvée"
                    },
                    "404": {
                        "description": "Catégorie non trouvée"
                    }
                }
            },
            "put": {
                "tags": [
                    "Categories"
                ],
                "summary": "Mettre à jour une catégorie",
                "description": "Update the specified resource in storage.",
                "operationId": "f0ae08633275192b3fe68efa358b9abd",
                "parameters": [
                    {
                        "name": "categorie",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "properties": {
                                    "nom": {
                                        "type": "string"
